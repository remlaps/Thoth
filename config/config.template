### DO NOT COPY KEYS into config.template
###    - Make sure LLM/LLM_API_KEY and STEEM/POSTING_KEY are both empty before saving in github!!!
###

[LLM]
# ArliAI info here - https://www.arliai.com/quick-start
# Gemini info here - https://ai.google.dev/gemini-api/docs/quickstart
##### ArliAI switched their free tier to Qwen3.5-27B-Derestricted.

### LLM_API_KEY = # This can be pulled from an environment variable.   ***DO NOT USE THIS / PROTECT YOUR KEY***
#ARLIAI example
### LLM_MODEL = Qwen3.5-27B-Derestricted
### LLM_URL = https://api.arliai.com/v1/chat/completions

#Gemini example
LLM_MODEL = gemini-2.5-pro, gemini-2.5-flash, gemini-2.0-flash-lite, gemini-2.0-flash
LLM_URL = https://generativelanguage.googleapis.com/v1beta/openai/chat/completions

INITIAL_BACKOFF_SECONDS = 15.0
JITTER_FACTOR = 0.2
MAX_RETRIES = 9
###
### Language options are English, German, or Spanish.
###
OUTPUT_LANGUAGE = English
SYSTEM_PROMPT_FILE = config\systemPrompt.txt
SYSTEM_PROMPT_TEMPLATE = config\systemPromptTemplate.txt
USER_PROMPT_FILE = config\userPrompt.txt
USER_PROMPT_TEMPLATE = config\userPromptTemplate.txt
# Feature flags for model switching behavior
# When True, enable automatic switching to the next model in the list if rate-limited
LLM_ENABLE_MODEL_SWITCHING = False
# When True (and LLM_ENABLE_MODEL_SWITCHING is True), log rate-limit events but do not actually switch models
LLM_MODEL_SWITCHING_DRY_RUN = False

# When True, skips making actual API calls to the LLM for curation and intro generation, inserting dummy text instead.
SKIP_AI_CURATION = False

